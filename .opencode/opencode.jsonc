{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "opencode": {
      "options": {},
    },
  },
  "mcp": {},
  "hooks": {
    "directory-readme-injector": {
      "enabled": false,
    },
  },
  "memory": {
    "hindsight": {
      "enabled": true,
      "llm_provider": "openai/gpt-5.4",
      "startup_timeout_ms": 120000,
      "query_timeout_ms": 20000,
    },
  },
  "tools": {
    "github-triage": false,
    "github-pr-search": false,
  },
  "agent": {
    // Test-Runner — 测试验证 Agent，跑测试 + 检查结果，不改代码
    "test-runner": {
      "model": "bytedance_ark/ep-20250704114927-l5l54",
      "mode": "subagent",
      "description": "Run tests and verify code changes. Use build-verify and test-analyze skills first.",
      "permission": {
        "bash": "allow",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "memory_remember": "allow",
        "memory_list": "allow",
        "memory_forget": "allow",
        "edit": "deny",
        "write": "deny",
      },
    },
    // Momus — Review Agent，专项检查 TUI renderable 问题
    "momus": {
      "permission": {
        "skill": "allow",
      },
      "options": {
        "enabled": true,
        "prompt_append": "When reviewing changes that touch `packages/opencode/src/cli/cmd/tui/**/*.tsx`, OpenTUI components, or text rendering paths, load the `tui-renderable-review` skill and apply its checklist. Flag explicit `children={...}` on custom components, suspicious values flowing into `<text>...</text>`, and mixed control-flow/components that may produce non-renderable text nodes.",
      },
    },
  },
}
