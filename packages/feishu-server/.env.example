# Feishu Auth Server — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# Server
PORT=3456
ISSUER_URL=https://your-server.example.com

# Feishu App (from https://open.feishu.cn)
APP_ID=cli_xxxxxxxxxx
APP_SECRET=xxxxxxxxxxxxxxxx
FEISHU_BASE_URL=https://open.feishu.cn

# RSA Keys (for JWT signing, generate with: openssl genrsa 2048)
# Paste the full PEM content including -----BEGIN/END----- lines
RSA_PRIVATE_KEY=
RSA_PUBLIC_KEY=

# Upstream API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_BASE_URL=https://api.openai.com

# JWT TTL in seconds (default: 48 hours)
JWT_TTL=172800
